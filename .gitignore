# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
# ---------------------------------------------------
# ADDED FOR WINDOWS DESKTOP & SECURITY
# ---------------------------------------------------

# Windows specific
windows/flutter/ephemeral/
windows/runner/Debug/
windows/runner/Release/
windows/runner/profile/
*.exe
*.dll
*.lib
*.exp
*.pdb
*.ilk

# Environment Variables (Keep your tokens safe!)
.env
# macOS / Linux build outputs (if you ever build for them)
macos/Flutter/ephemeral/
linux/flutter/ephemeral/

# Android signing keys — critical, never commit these
**/android/key.properties
**/android/app/upload-keystore.jks
**/*.jks
**/*.keystore

# iOS specific
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.podspec

# Generated localization files (if using intl/gen-l10n)
**/lib/generated_plugin_registrant.dart
**/lib/l10n/generated/

# VS Code workspace-specific settings some teams exclude (optional, you already commented out .vscode/)
*.code-workspace

# Local database files if SQLite db ever gets created in project root during dev/testing
*.db
*.sqlite
*.sqlite3

# Backup/editor swap files
*~
*.bak
*.orig

# OS-specific junk
Thumbs.db
erp_backend/